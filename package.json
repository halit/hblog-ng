{
  "name": "hblog-ng",
  "version": "0.1.0",
  "description": "A non-linear knowledge graph blog built on top of Obsidian and Next.js",
  "author": "Halit Alptekin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/halit/hblog-ng.git"
  },
  "keywords": [
    "obsidian",
    "nextjs",
    "blog",
    "knowledge-graph",
    "static-site-generator",
    "markdown",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "dev": "npm run prepare-data && tsx scripts/dev-server.ts",
    "watch-data": "tsx scripts/watch-data.ts",
    "prepare-data": "npm run parse-vault && npm run parse-bibtex && npm run optimize-images && npm run generate-og-images && tsx scripts/copy-static-assets.ts",
    "build": "npm run prepare-data && next build",
    "deploy": "npm run build && wrangler pages deploy",
    "generate-og-images": "tsx scripts/generate-og-images.ts",
    "sign-posts": "tsx scripts/sign-posts.ts",
    "parse-bibtex": "tsx scripts/parse-bibtex.ts",
    "analyze": "ANALYZE=true next build --webpack",
    "optimize-images": "tsx scripts/optimize-images.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "parse-vault": "tsx scripts/parse-vault.ts",
    "serve": "npx serve out"
  },
  "dependencies": {
    "asciinema-player": "^3.12.1",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.25",
    "lucide-react": "^0.554.0",
    "marked": "^17.0.1",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.1.0",
    "minisearch": "^7.2.0",
    "next": "^16.0.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-katex": "^3.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.5.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sanitize-html": "^2.17.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@next/bundle-analyzer": "^16.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/html2canvas": "^0.5.35",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-katex": "^3.0.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/sanitize-html": "^2.16.0",
    "@types/sharp": "^0.31.1",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.8.32",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "mermaid": "^10.9.5",
    "openpgp": "^6.2.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2",
    "vitest": "^4.1.8",
    "wrangler": "^4.51.0"
  }
}
