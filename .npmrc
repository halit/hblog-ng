# Supply-chain cooldown: never resolve a package version that has been public
# for fewer than this many days. Mitigates compromised-version attacks (a bad
# release is usually caught and unpublished within hours/days). Applies only
# when npm RESOLVES new versions (npm update / npm install <pkg> / no lockfile);
# `npm ci` and lockfile-satisfied installs use already-vetted pinned versions.
# Tradeoff: also delays legitimate security patches by the same window — bump
# urgent fixes manually with `npm i <pkg>@x --min-release-age=0`.
min-release-age=7
