# Public site configuration.
#
# These NEXT_PUBLIC_* values are inlined into the static build, so everything
# here is public by design. This file is committed and holds the project's
# default identity. To override any value locally without touching this file,
# create a git-ignored `.env.local`.
#
# Private material (PGP keys, passphrases) must NEVER go here — keep it in
# `.env.local` (ignored) or pass it through the environment at build time.

# Site metadata
NEXT_PUBLIC_SITE_TITLE="Halit Alptekin"
NEXT_PUBLIC_SITE_DESCRIPTION="Cyber security researcher breaking and defending critical infrastructure. Malware analysis, penetration testing, threat intelligence, and APT research."
NEXT_PUBLIC_SITE_URL="https://halit.alptekin.im"
NEXT_PUBLIC_AUTHOR_NAME="Halit Alptekin"
NEXT_PUBLIC_AUTHOR_EMAIL="halit@alptekin.im"

# Social handles
NEXT_PUBLIC_TWITTER_HANDLE="crimedisruptor"
NEXT_PUBLIC_LINKEDIN_HANDLE="halitalptekin"
NEXT_PUBLIC_GITHUB_HANDLE="halit"

# Note: the app version is not configurable here. It is read directly from
# package.json (config/env.ts). Bump the version in package.json only.

# Vault location (optional). Falls back to ./vault, then ./example-vault.
# VAULT_PATH="/path/to/your/obsidian/vault"

# PGP signature verification (public key only — safe to commit if you want it
# baked in). Private key, key id, and passphrase belong in .env.local.
# NEXT_PUBLIC_PGP_PUBLIC_KEY_PATH=".secrets/public.asc"
